PORT=4000
JWT_SECRET=pon-aqui-un-secreto-largo-y-aleatorio

# Servidor SIP del dialer (tu dominio). Los clientes ven este valor en MicroSIP como SIP Server y Domain; no ven al proveedor de minutos. Ej: callship.com o sip.callship.com
CALLSHIP_SIP_SERVER=

# PostgreSQL
# En Railway: añade el plugin "PostgreSQL" al proyecto; te dará DATABASE_URL y los usuarios persistirán entre deploys.
# Si no hay DATABASE_URL, se usan las variables de abajo (ej. desarrollo local).
DATABASE_URL=
PG_HOST=localhost
PG_PORT=5432
PG_USER=callship
PG_PASSWORD=callship123
PG_DATABASE=callship_db

# OxaPay (TopUp / Crypto)
# 1) Panel OxaPay → Merchant Service → crea una Merchant API Key (no Payout API).
# 2) Si activas "Allowed IPs", añade la IP de este servidor (en la app: Billing → "Ver IP del servidor").
# 3) Pega aquí la clave sin espacios extra.
OXAPAY_MERCHANT_API_KEY=pon_tu_api_key_aqui
# Donde vuelve el usuario al terminar el pago (tu web)
OXAPAY_RETURN_URL=http://localhost:3000
# Callback/webhook (tu servidor público en producción)
OXAPAY_CALLBACK_URL=http://localhost:4000/api/oxapay/callback
# Sandbox (true = pruebas sin dinero real)
OXAPAY_SANDBOX=true

# Correo (recuperar contraseña) - Gmail
# Sin esto, "Olvidé contraseña" no enviará el correo (503).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=contraseña_de_aplicacion_gmail
EMAIL_FROM=tu_correo@gmail.com
FRONTEND_URL=https://www.callship.us

# Webhook OxaPay (opcional): si lo defines, el callback exige header X-Webhook-Secret con este valor
# OXAPAY_WEBHOOK_SECRET=

# Recarga manual (respaldo si OxaPay falla): direcciones de billetera cripto para mostrar a clientes.
# Opción 1: variables sueltas (se muestran BTC, ETH, USDT TRC20 si tienen valor)
# CRYPTO_BTC_ADDRESS=
# CRYPTO_ETH_ADDRESS=
# CRYPTO_USDT_TRC20_ADDRESS=
# Opción 2: JSON en CRYPTO_WALLETS con logo y red. Ejemplo:
# CRYPTO_WALLETS=[{"currency":"BTC","network":"Bitcoin","address":"tu_direccion","logo":"₿"},{"currency":"USDT","network":"TRC20","address":"tu_trc20","logo":"₮"}]
